{
  "name": "protrader-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "vite build && node scripts/server.mjs",
    "serve": "node scripts/server.mjs",
    "dev": "vite",
    "build": "vite build",
    "scan": "node scripts/screener.mjs",
    "content": "node scripts/contentEngine.mjs && node scripts/contentImages.mjs",
    "post": "node scripts/poster.mjs",
    "angel": "node scripts/angelClient.mjs",
    "test": "node tests/run-tests.mjs && node tests/func.mjs",
    "test:unit": "node tests/run-tests.mjs",
    "test:func": "node tests/func.mjs",
    "test:perf": "node tests/perf.mjs"
  },
  "dependencies": {
    "lightweight-charts": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^4.3.4",
    "puppeteer-core": "^25.1.0",
    "tailwindcss": "^4.1.11",
    "vite": "^5.4.11"
  }
}
